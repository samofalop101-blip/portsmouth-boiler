# ─────────────────────────────────────────────────────────────
#  .env.example  —  Copy this to .env and fill in your values
#  NEVER commit your real .env file to Git
# ─────────────────────────────────────────────────────────────

# Gmail address used to SEND emails (the "from" account)
MAIL_USER=youraddress@gmail.com

# Gmail App Password (NOT your login password)
# How to generate: Gmail → Settings → Security → 2-Step Verification → App Passwords
# Choose "Mail" and your device, then copy the 16-character password here
MAIL_PASS=xxxx xxxx xxxx xxxx

# Work email address where ALL enquiries will be delivered
WORK_EMAIL=info@boilerrepairinportsmouth.co.uk

# Port the server runs on (3000 is default, change if needed)
PORT=3000
